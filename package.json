{
  "name": "easy-offer",
  "version": "1.0.0",
  "description": "Generate a tailored resume and interview prep plan from your GitHub history using any OpenAI-compatible LLM",
  "bin": {
    "easy-offer": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "marked": "^12.0.0",
    "openai": "^6.34.0",
    "ora": "^8.0.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.0.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
